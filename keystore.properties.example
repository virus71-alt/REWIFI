# Copy this file to "keystore.properties" (same folder) and fill in real values.
# keystore.properties is gitignored — NEVER commit your real keystore or passwords.
#
# Generate a release keystore once (keep the .jks file + passwords safe forever —
# you need the SAME key to ship updates):
#
#   keytool -genkeypair -v -keystore rewifi-release.jks \
#       -alias rewifi -keyalg RSA -keysize 2048 -validity 10000
#
# Then get its SHA-1 to register a Google OAuth client:
#
#   keytool -list -v -keystore rewifi-release.jks -alias rewifi

storeFile=../rewifi-release.jks
storePassword=CHANGE_ME
keyAlias=rewifi
keyPassword=CHANGE_ME
